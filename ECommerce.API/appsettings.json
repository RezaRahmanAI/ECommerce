{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=REZA;Initial Catalog=sherashobBD24;Integrated Security=True;Max Pool Size=50;MultipleActiveResultSets=False;TrustServerCertificate=True;"
  },
  "Token": {
    "Key": "this_is_a_very_long_secret_key_for_development_purpose_only_12345",
    "Issuer": "https://api.arzamart.shop",
    "Audience": "https://arzamart.shop"
  },
  "Auth": {
    "CookieDomain": ".arzamart.shop"
  },
  "AllowedOrigins": [
    "http://localhost:4200",
    "https://localhost:4200",
    "https://arzamart.shop",
